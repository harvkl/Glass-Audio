<Window x:Class="Glass_Audio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Glass_Audio"
        mc:Ignorable="d"
        Title="Glass Audio" Height="270" Width="510"
        Topmost="True"
        Icon="/resources/media/Icon.png"
        WindowStyle="None"
        ResizeMode="NoResize" 
        Background="#FFD9D9D9">

    <Window.Resources>
        <Style x:Key="FirstLabel">
            <Setter Property="Control.HorizontalContentAlignment" Value="Center"></Setter>
            <Setter Property="Control.VerticalContentAlignment" Value="Bottom"></Setter>
            <Setter Property="Control.FontFamily" Value="Roboto"></Setter>
            <Setter Property="Control.FontSize" Value="21"></Setter>
            <Setter Property="Control.BorderThickness" Value="0"></Setter>
            <Setter Property="Control.Foreground" Value="#FF3C3C3C"></Setter>
        </Style>

        <Style x:Key="SecondLabel">
            <Setter Property="Control.HorizontalContentAlignment" Value="Center"></Setter>
            <Setter Property="Control.VerticalContentAlignment" Value="Bottom"></Setter>
            <Setter Property="Control.FontFamily" Value="Roboto"></Setter>
            <Setter Property="Control.FontSize" Value="15"></Setter>
            <Setter Property="Control.BorderThickness" Value="0"></Setter>
            <Setter Property="Control.Foreground" Value="#FF636363"></Setter>
        </Style>

        <Style x:Key="VolumeIcon">
            <Setter Property="Control.BorderBrush" Value="Black"></Setter>
            <Setter Property="Control.BorderThickness" Value="1"></Setter>
        </Style>

        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Control.HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="Control.VerticalAlignment" Value="Center"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Width="4" Background="#B2000000" CornerRadius="2"></Border>

                            <Track x:Name="PART_Track">
                                <!-- THIS THUMB NEEDS EXACTLY BE NAMED AS "PART_Track" otherwise it won't react on drags-->

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"></Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"></Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Name="SliderThumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Rectangle x:Name="ThumbRectangle"
                                                        Width="25"
                                                        Height="10"
                                                        RadiusX="3"
                                                        RadiusY="3"
                                                        Fill="White"
                                                        Stroke="Black"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InteractionPanelButton">
            <Setter Property="Control.Background" Value="{x:Null}"></Setter>
            <Setter Property="Control.BorderBrush" Value="{x:Null}"></Setter>
            <Setter Property="Control.BorderThickness" Value="0"></Setter>

            <!-- Removes the ugly dotted focus ring -->
            <Setter Property="Control.FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Control.Cursor" Value="Hand" />

            <!-- Crucial: Makes the button scale from its center, not the top-left corner -->
            <Setter Property="Control.RenderTransformOrigin" Value="0.5, 0.5" />
            <Setter Property="Control.RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>

            <!-- Strips away the default Windows template (removes the blue hover) -->
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- The Hover Animation -->
            <Style.Triggers>
                <Trigger Property="Control.IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InteractionPanelImg">
            <Setter Property="Control.BorderBrush" Value="Black"></Setter>
            <Setter Property="Control.BorderThickness" Value="1"></Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="GridMainWindow" ShowGridLines="False">

        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Button x:Name="CollapseButton" Grid.Column="15" Grid.Row="1" Width="30" Height="30" Click="ButtonClick_CollapseExpand" Style="{StaticResource InteractionPanelButton}">
            <Image x:Name="CollapseImgButton" Width="30" Height="30" Source="/resources/media/collapse.png"></Image>
        </Button>

        <Image x:Name="Preview" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="3" Grid.RowSpan="3" Source="./resources/media/PreviewImage.png"></Image>

        <StackPanel x:Name="TextPanel" Grid.Column="5" Grid.Row="1" Grid.ColumnSpan="10" Grid.RowSpan="3" Width="300" Height="60" VerticalAlignment="Top">
            <Label x:Name="FirstLabel" Grid.Column="5" Grid.Row="1" Grid.ColumnSpan="10" Width="300" Height="35" FontWeight="DemiBold" Content="First Label" Style="{StaticResource FirstLabel}"></Label>
            <Label x:Name="SecondLabel" Grid.Column="5" Grid.Row="3" Grid.ColumnSpan="10" Width="300" Height="30" Content="Second Label" Style="{StaticResource SecondLabel}"></Label>
        </StackPanel>

        <StackPanel x:Name="VolumePanel" Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="2" Grid.RowSpan="3" Width="60" Height="90" Orientation="Horizontal">
            <Button x:Name="VolumeButton" Grid.Column="1" Grid.Row="5" Width="30" Height="30" Click="MuteClick" Style="{StaticResource InteractionPanelButton}">
                <Image x:Name="VolumeIcon" Width="25" Height="25" Source="./resources/media/Volume x.png" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource VolumeIcon}"></Image>
            </Button>
            <Slider x:Name="VolumeSlider" Grid.Column="2" Grid.Row="5" Grid.RowSpan="3" Width="30" Height="90" Orientation="Vertical" Value="0" Minimum="0" Maximum="100" ValueChanged="VolumeSlider_ValueChanged" SelectionStart="0" Style="{StaticResource VolumeSlider}"/>
        </StackPanel>

        <StackPanel x:Name="InteractionPanel" Grid.Column="7" Grid.Row="5" Grid.ColumnSpan="6" Grid.RowSpan="3" Width="180" Height="90" Orientation="Horizontal">
            <Button x:Name="PrevButton" Grid.Column="7" Grid.Row="6" Grid.ColumnSpan="1" Grid.RowSpan="2" Width="60" Height="30" Click="PrevClick" Style="{StaticResource InteractionPanelButton}">
                <Image x:Name="PrevImg" Width="28" Height="28" Source="/resources/media/Arrow left-circle.png" Style="{StaticResource InteractionPanelImg}"></Image>
            </Button>
            <Button x:Name="PlayPauseButton" Grid.Column="9" Grid.Row="6" Grid.ColumnSpan="2" Grid.RowSpan="3" Width="60" Height="60" Click="PlayPauseClick" Style="{StaticResource InteractionPanelButton}">
                <Image x:Name="PlayPauseImg" Source="/resources/media/Play circle.png" Width="60" Height="60" Style="{StaticResource InteractionPanelImg}"></Image>
            </Button>
            <Button x:Name="NextButton" Grid.Column="11" Grid.Row="6" Grid.ColumnSpan="1" Grid.RowSpan="2" Width="60" Height="30" Click="NextClick" Style="{StaticResource InteractionPanelButton}">
                <Image x:Name="NextImg" Source="/resources/media/Arrow right-circle.png" Width="28" Height="28" Style="{StaticResource InteractionPanelImg}"></Image>
            </Button>
        </StackPanel>

        <Button x:Name="SettingsButton" Grid.Column="15" Grid.Row="7" Width="30" Height="30" Click="ButtonClick_Settings" Style="{StaticResource InteractionPanelButton}">
            <Image Width="28" Height="28" Source="./resources/media/Settings.png"></Image>
        </Button>
    </Grid>
</Window>
